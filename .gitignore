# Secrets — NEVER commit these
config.json
Walk_Dash_API_key.txt
*.env
.env
ANTHROPIC_API_KEY.txt
drive-service-account.json
.venv/
venv/

# Generated outputs (data/outputs/) — not committed; rebuilt at deploy time
data/outputs/
# Exception: transit_matrix.json is expensive to regenerate and has no auth requirement
!data/outputs/site/transit_matrix.json
!data/outputs/site/routes_data.json

# Runtime ephemeral state — never committed
data/runtime/local/
data/runtime/persisted/drive_seen_files.json

# Collector schedule PDFs (privacy — named individuals)
data/inputs/collectors/
# Legacy location also excluded
Collector_Schedule/

# Forecast PDFs (large, delivered via Google Drive)
data/inputs/forecasts/*.pdf
!data/inputs/forecasts/.gitkeep
# Legacy location also excluded
Forecast/*.pdf

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/

# Claude Code IDE local config
.claude/

# OS artifacts
.DS_Store
Thumbs.db
