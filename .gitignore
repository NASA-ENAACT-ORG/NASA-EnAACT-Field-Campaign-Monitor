# Secrets and runtime state — never commit these
config.json
Walk_Dash_API_key.txt
drive_seen_files.json
*.env
.env

# Generated HTML/JSON outputs (rebuilt by serve.py)
dashboard.html
collector_map.html
schedule_map.html
schedule_output.json

# Personal collector schedule files (privacy — named individuals)
Collector_Schedule/

# Forecast PDFs (delivered via Google Drive, not source code)
Forecast/*.pdf
!Forecast/.gitkeep

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/

# Claude Code IDE local config
.claude/

# Binary Office docs (not well version-controlled)
Architecture_Overview.docx

# OS artifacts
.DS_Store
Thumbs.db
